# WATT-IF Backend Environment Variables
# Copy this file to .env and fill in the values.

# Secret key for signing JWT tokens (minimum 32 characters).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-strong-random-secret-key-at-least-32-chars

# (Optional) Comma-separated allowed origins for CORS.
# Leave empty or omit to allow all origins (convenient for development).
# Example: CORS_ORIGINS=http://localhost:5173,http://192.168.1.50:5173
CORS_ORIGINS=
